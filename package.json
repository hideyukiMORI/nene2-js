{
  "name": "@hideyukimori/nene2-client",
  "version": "0.0.0",
  "private": true,
  "description": "TypeScript client ecosystem for NENE2 JSON APIs (OpenAPI-aligned)",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hideyukiMORI/nene2-js.git"
  },
  "engines": {
    "node": ">=22 <25",
    "npm": ">=10 <12"
  },
  "packageManager": "npm@11",
  "scripts": {
    "type-check": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "test": "vitest run",
    "contracts:sync": "node tools/sync-openapi.mjs",
    "contracts:check": "node tools/sync-openapi.mjs --check",
    "check": "npm run type-check && npm run lint && npm run format && npm run contracts:check && npm run test"
  },
  "keywords": [
    "nene2",
    "openapi",
    "typescript",
    "api-client",
    "problem-details"
  ],
  "devDependencies": {
    "@eslint/js": "^9.39.3",
    "eslint": "^9.39.3",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.3",
    "vitest": "^4.0.18"
  }
}
