# Live smoke — set URLs for backends you have running (tests skip when unset).
# Probe order for FTs: NENE2 → nene2-python → nene2-node (ADR 0003).

# NENE2 PHP (canonical) — docker compose up -d app in ../NENE2
NENE2_JS_API_BASE_URL=http://localhost:8080

# nene2-python — e.g. uv run uvicorn src.example.app:app --port 8000
# NENE2_JS_PYTHON_BASE_URL=http://localhost:8000

# nene2-node — when health/ping are implemented (Phase 1+)
# NENE2_JS_NODE_BASE_URL=http://localhost:3000

# Optional: path to NENE2 OpenAPI for contracts:sync (default: ../NENE2/docs/openapi/openapi.yaml)
# Committed pin for CI: contracts/openapi.yaml — see docs/adr/0002-openapi-contract-pin-policy.md
# NENE2_JS_OPENAPI_PATH=../NENE2/docs/openapi/openapi.yaml

# Do not commit real secrets. Use consumer app env for:
# NENE2_MACHINE_API_KEY=...
# NENE2_LOCAL_JWT_SECRET=...
